# Backend Service Port
PORT=3000

# Database Connection URI (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/enterpriseiq?schema=public"

# Frontend Application Origin (CORS limitation)
FRONTEND_URL="http://localhost:3000"

# JWT Secret Keys & Expiries
JWT_SECRET="placeholder_jwt_secret_key"
JWT_REFRESH_SECRET="placeholder_jwt_refresh_secret_key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google Gemini API Key
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL=
